+    bus.emitRecord('item', 'created', { id: 'pack', actorId: 'a1', isContainer: true }, undefined, 'remote')
+    bus.emitRecord('item', 'created', { id: 'rope', actorId: 'a1', parentItemId: 'pack' }, undefined, 'remote')
